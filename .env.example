# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# App URL (required)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Extension CORS (required — get your extension ID from chrome://extensions after loading)
ALLOWED_EXTENSION_ORIGINS=chrome-extension://your-extension-id

# AI Provider — pick one (required for qualification + InMail generation)
AI_GATEWAY_API_KEY=your-vercel-ai-gateway-key
# ANTHROPIC_API_KEY=your-anthropic-api-key  # Fallback if not using Vercel AI Gateway

# AI — optional overrides
# AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1
# AI_QUALIFY_MODEL=anthropic/claude-sonnet-4-20250514
# AI_INTRO_MODEL=anthropic/claude-sonnet-4-20250514
