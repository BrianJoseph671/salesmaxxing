{
	"name": "salesmaxxing",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.10",
	"description": "SalesMAXXing Agent - AI-powered lead qualification from your LinkedIn network",
	"scripts": {
		"dev": "next dev --turbopack",
		"build": "bun run ext:zip && next build",
		"start": "next start",
		"lint": "bunx biome check .",
		"lint:fix": "bunx biome check --write .",
		"format": "bunx biome format --write .",
		"typecheck": "bunx tsc --noEmit",
		"check": "bun run lint && bun run typecheck && bun run build && bun run ext:build",
		"ext:dev": "bun run scripts/build-extension.ts --watch",
		"ext:build": "bun run scripts/build-extension.ts",
		"ext:zip": "bun run scripts/package-extension.ts",
		"deploy:prod": "vercel --prod"
	},
	"dependencies": {
		"@ai-sdk/anthropic": "^3.0.58",
		"@ai-sdk/openai": "^3.0.41",
		"@supabase/ssr": "^0.9.0",
		"@supabase/supabase-js": "^2.98.0",
		"@vercel/analytics": "^1.6.1",
		"@vercel/speed-insights": "^1.3.1",
		"ai": "^6.0.116",
		"clsx": "^2.1.1",
		"lucide-react": "^0.577.0",
		"next": "^16.1.6",
		"next-themes": "^0.4.6",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"tailwind-merge": "^3.5.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@tailwindcss/postcss": "^4.2.1",
		"@types/bun": "^1.3.10",
		"@types/chrome": "^0.0.304",
		"@types/node": "^25.3.5",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"postcss": "^8.5.8",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.9.3"
	}
}
